# Database
DATABASE_URL="postgresql://user:password@localhost:5432/linkforge"

# Redis (for caching and analytics queue)
REDIS_URL="redis://localhost:6379"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
BASE_URL="http://localhost:4000"

# JWT Tokens
JWT_ACCESS_SECRET="generate-a-random-64-char-secret-here-must-be-changed-in-production"
JWT_REFRESH_SECRET="generate-another-random-64-char-secret-here-must-be-changed-in-production"

# Analytics
ANALYTICS_SALT="change-this-to-a-random-string"
