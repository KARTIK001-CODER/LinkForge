# =============================================================================
# LinkForge Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/linkforge"

# --- Redis ---
# Redis connection string for caching and analytics event stream
REDIS_URL="redis://localhost:6379"

# --- Server ---
PORT=4000
NODE_ENV=development
# The URL where your frontend is hosted (for CORS and redirects)
FRONTEND_URL="http://localhost:5173"
# The public base URL of this backend
BASE_URL="http://localhost:4000"

# --- JWT Tokens ---
# Generate with: openssl rand -base64 64 | tr -dc 'A-Za-z0-9' | head -c 64
JWT_ACCESS_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING"

# --- Analytics ---
# Salt used for hashing visitor IPs + user agents (anonymization)
# Generate with: openssl rand -base64 32
ANALYTICS_SALT="CHANGE_ME_TO_A_RANDOM_STRING"
