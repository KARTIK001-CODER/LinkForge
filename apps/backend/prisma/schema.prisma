generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique @db.VarChar(255)
  username          String   @unique @db.VarChar(50)
  displayName       String?  @db.VarChar(100)
  passwordHash      String   @db.VarChar(255)
  avatarUrl         String?  @db.VarChar(500)
  role              String   @default("USER") @db.VarChar(20)
  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)
  loginAttempts     Int      @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  refreshTokens     RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  auditLogs         AuditLog[]
  links             SmartLink[]
  collections       Collection[]

  @@index([email])
  @@index([username])
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @db.VarChar(255)
  deviceInfo  String?   @db.VarChar(255)
  ipAddress   String?   @db.VarChar(45)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(50)
  resource   String?  @db.VarChar(50)
  resourceId String?  @db.VarChar(100)
  details    Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SmartLink {
  id             String   @id @default(uuid())
  userId         String?
  owner          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinationUrl String   @db.VarChar(2048)
  alias          String   @unique @db.VarChar(50)
  passwordHash   String?  @db.VarChar(255)
  startsAt       DateTime?
  expiresAt      DateTime?
  fallbackUrl    String?  @db.VarChar(2048)
  status         String   @default("ACTIVE") @db.VarChar(20)
  title          String?  @db.VarChar(100)
  description    String?  @db.VarChar(500)
  tags           Json?    @default("[]")
  clicks         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isFavorite     Boolean  @default(false)
  collectionId   String?
  trafficVariants Json?   @default("[]")
  collection     Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  rules          RedirectRule[]

  analyticsEvents AnalyticsEvent[]
  hourlyMetrics   HourlyMetrics[]
  dailyMetrics    DailyMetrics[]
  monthlyMetrics  MonthlyMetrics[]
  aggregatedMetrics AggregatedMetrics[]
  exportJobs      ExportJob[]
  visitorSessions VisitorSession[]

  @@index([userId])
}

model Collection {
  id          String      @id @default(uuid())
  userId      String?
  owner       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String      @db.VarChar(100)
  description String?     @db.VarChar(500)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  links       SmartLink[]

  @@index([userId])
}

model RedirectRule {
  id             String    @id @default(uuid())
  linkId         String
  link           SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  priority       Int
  destinationUrl String    @db.VarChar(2048)
  conditions     Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([linkId, priority])
}

model Visitor {
  id        String   @id @default(uuid())
  hash      String   @unique @db.VarChar(255) // Hashed IP + UA + daily salt
  createdAt DateTime @default(now())
  
  events    AnalyticsEvent[]
  sessions  VisitorSession[]
}

model VisitorSession {
  id        String   @id @default(uuid())
  visitorId String
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  linkId    String
  link      SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  startedAt DateTime @default(now())
  endedAt   DateTime?
  
  @@index([visitorId, linkId])
  @@index([linkId])
}

model AnalyticsEvent {
  id              String   @id @default(uuid())
  linkId          String
  link            SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  alias           String?  @db.VarChar(50)
  ownerId         String?  @db.VarChar(100)
  sessionId       String?  @db.VarChar(100)
  visitorId       String?
  visitor         Visitor?  @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  timestamp       DateTime @default(now())
  
  ipHash          String?  @db.VarChar(255)
  country         String?  @db.VarChar(50)
  region          String?  @db.VarChar(100)
  city            String?  @db.VarChar(100)
  timezone        String?  @db.VarChar(100)
  language        String?  @db.VarChar(50)
  
  browser         String?  @db.VarChar(50)
  browserVersion  String?  @db.VarChar(50)
  os              String?  @db.VarChar(50)
  osVersion       String?  @db.VarChar(50)
  deviceType      String?  @db.VarChar(50)
  platform        String?  @db.VarChar(50)
  userAgent       String?  @db.VarChar(500)
  
  referrer        String?  @db.VarChar(255)
  referrerUrl     String?  @db.VarChar(2048)
  
  utmSource       String?  @db.VarChar(100)
  utmMedium       String?  @db.VarChar(100)
  utmCampaign     String?  @db.VarChar(100)
  utmContent      String?  @db.VarChar(100)
  utmTerm         String?  @db.VarChar(100)
  
  redirectDuration Int?   @default(0)
  httpStatus      Int?    @default(302)
  
  @@index([linkId, timestamp])
  @@index([linkId, country])
  @@index([linkId, browser])
  @@index([linkId, os])
  @@index([linkId, deviceType])
  @@index([linkId, referrer])
  @@index([linkId, visitorId])
  @@index([linkId, alias])
  @@index([linkId, ownerId])
  @@index([ownerId, timestamp])
  @@index([timestamp])
  @@index([visitorId, timestamp])
}

model HourlyMetrics {
  id              String   @id @default(uuid())
  linkId          String
  link            SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  hour            DateTime
  totalClicks     Int      @default(0)
  uniqueVisitors  Int      @default(0)
  
  @@unique([linkId, hour])
  @@index([linkId, hour])
}

model DailyMetrics {
  id              String   @id @default(uuid())
  linkId          String
  link            SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  totalClicks     Int      @default(0)
  uniqueVisitors  Int      @default(0)
  
  @@unique([linkId, date])
  @@index([linkId, date])
}

model MonthlyMetrics {
  id              String   @id @default(uuid())
  linkId          String
  link            SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  month           DateTime @db.Date
  totalClicks     Int      @default(0)
  uniqueVisitors  Int      @default(0)
  
  @@unique([linkId, month])
  @@index([linkId, month])
}

model AggregatedMetrics {
  id          String   @id @default(uuid())
  linkId      String
  link        SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  dimension   String   @db.VarChar(50) // e.g. "country", "browser", "referrer"
  value       String   @db.VarChar(255) // e.g. "US", "Chrome", "google.com"
  clicks      Int      @default(0)
  
  @@unique([linkId, dimension, value])
}

model ExportJob {
  id          String   @id @default(uuid())
  linkId      String
  link        SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") @db.VarChar(20)
  fileUrl     String?  @db.VarChar(2048)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
}
